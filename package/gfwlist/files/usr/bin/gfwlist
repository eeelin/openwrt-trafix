#!/bin/sh

BINDIR="$(dirname "$0")"
CONF_PATH=/etc/gfwlist/gfwlist.yaml
NAMES_CONF=/var/gfwlist/names.conf
PROXY_IPSET_CONF=/etc/gfwlist/proxy-ipset-net.conf
PROXY_IP6SET_CONF=/etc/gfwlist/proxy-ip6set-net.conf
DNSMASQ_OUT=/tmp/dnsmasq.d/gfwlist.conf

log() {
	echo "$@"
}

err() {
	echo "$@" >&2
}

reset_conf() {
	[ -f "$1" ] && rm -f "$1"
	mkdir -p "$(dirname "$1")"
	: > "$1"
}

generate_dnsmasq_conf() {
	mkdir -p "$(dirname "$DNSMASQ_OUT")"
	"${BINDIR}/gfwlist2dnsmasq.sh" \
		-o "$DNSMASQ_OUT" \
		-p 6053 \
		-s gfwlist,gfwlist6 \
		--extra-domain-file "$NAMES_CONF"
}

process_rule() {
	content="$1"
	key="$(echo "$content" | cut -d ',' -f 1)"
	arg="$(echo "$content" | cut -d ',' -f 2-)"
	case "$key" in
		DOMAIN|DOMAIN-SUFFIX)
			echo "$arg" >> "$NAMES_CONF"
			;;
		IP-CIDR)
			echo "$arg" >> "$PROXY_IPSET_CONF"
			;;
		IP-CIDR6)
			echo "$arg" >> "$PROXY_IP6SET_CONF"
			;;
		'')
			;;
		*)
			err "unknown keyword $key"
			;;
	esac
}

update() {
	reset_conf "$NAMES_CONF"
	reset_conf "$PROXY_IPSET_CONF"
	reset_conf "$PROXY_IP6SET_CONF"

	for url in $(yq -r '.remoteRules[]?.url // empty' "$CONF_PATH"); do
		log "processing $url"
		for rule in $(curl -fsSL "$url" | yq -r '.payload[]? // empty'); do
			process_rule "$rule"
		done
	done

	for path in $(yq -r '.rules[]?.path // empty' "$CONF_PATH"); do
		log "processing $path"
		for rule in $(yq -r '.payload[]? // empty' "$path"); do
			process_rule "$rule"
		done
	done

	for name in $(yq -r '.names[]? // empty' "$CONF_PATH"); do
		echo "$name" >> "$NAMES_CONF"
	done

	generate_dnsmasq_conf
}

"$@"
