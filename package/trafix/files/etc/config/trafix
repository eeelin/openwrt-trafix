config trafix 'general'
	option redir_ipv4_port '1109'
	option redir_ipv6_port '1108'

	option tproxy_ipv4_port '2500'
	option tproxy_ipv6_port '2501'

	option block_proxy_http3 '1'

	option bypass_ipset_conf '/etc/trafix/bypass-ipset.conf'
	option bypass_ipset_net_conf '/etc/trafix/bypass-ipset-net.conf'

	option bypass_ip6set_conf '/etc/trafix/bypass-ip6set.conf'
	option bypass_ip6set_net_conf '/etc/trafix/bypass-ip6set-net.conf'

	option proxy_ipset_conf '/etc/trafix/proxy-ipset.conf'
	option proxy_ipset_net_conf '/etc/trafix/proxy-ipset-net.conf'

	option proxy_ip6set_conf '/etc/trafix/proxy-ip6set.conf'
	option proxy_ip6set_net_conf '/etc/trafix/proxy-ip6set-net.conf'
