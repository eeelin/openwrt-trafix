#!/bin/sh /etc/rc.common

START=70
STOP=60

USE_PROCD=0
EXTRA_COMMANDS="status dryrun_start dryrun_stop dryrun_restart"
EXTRA_HELP="        status          Print current network status\n\
\t    dryrun_start    Print commands that would be executed during start\n\
\t    dryrun_stop     Print commands that would be executed during stop\n\
\t    dryrun_restart  Print commands that would be executed during restart"

STATE_DIR=/var/trafix
RUNTIME_ENV="$STATE_DIR/runtime.env"
DRY_RUN="${TRAFIX_DRY_RUN:-0}"
DEFAULT_CONFIG_FILE=/etc/trafix/config.yaml
PROXY_IPSET_CONF="$STATE_DIR/proxy-ipset.conf"
PROXY_IPSET_NET_CONF="$STATE_DIR/proxy-ipset-net.conf"
PROXY_IP6SET_CONF="$STATE_DIR/proxy-ip6set.conf"
PROXY_IP6SET_NET_CONF="$STATE_DIR/proxy-ip6set-net.conf"

BYPASS_IPSET_CONF="$STATE_DIR/bypass-ipset.conf"
BYPASS_IPSET_NET_CONF="$STATE_DIR/bypass-ipset-net.conf"
BYPASS_IP6SET_CONF="$STATE_DIR/bypass-ip6set.conf"
BYPASS_IP6SET_NET_CONF="$STATE_DIR/bypass-ip6set-net.conf"

BLOCK_IPSET_CONF="$STATE_DIR/block-ipset.conf"
BLOCK_IPSET_NET_CONF="$STATE_DIR/block-ipset-net.conf"
BLOCK_IP6SET_CONF="$STATE_DIR/block-ip6set.conf"
BLOCK_IP6SET_NET_CONF="$STATE_DIR/block-ip6set-net.conf"

check_ip() {
	prompt="$1"
	cip="$2"
	[ -n "$cip" ] || return 0
	info="$(curl -s "https://ipinfo.io/${cip}" | jq -r '.city + " / " + .country' 2>/dev/null)"
	echo "${prompt} --> ${cip} [${info}]"
}

resolve_config_file() {
	config_file="${TRAFIX_CONFIG:-}"
	if [ -z "$config_file" ] && command -v uci >/dev/null 2>&1; then
		config_file="$(uci -q get trafix.general.config_file 2>/dev/null)"
	fi
	if [ -z "$config_file" ]; then
		config_file="$DEFAULT_CONFIG_FILE"
	fi
	echo "$config_file"
}

run_cmd() {
	if [ "$DRY_RUN" = 1 ]; then
		echo "+ $*"
	else
		eval "$@"
	fi
}

test_dns_domain() {
	family="$1"
	domain="$2"
	label_family="$(printf "%s" "$family" | tr "[:lower:]" "[:upper:]")"
	case "$family" in
		ipv4)
			record_type="a"
			;;
		ipv6)
			record_type="aaaa"
			;;
		*)
			return 1
			;;
	esac
	gip="$(dig "$domain" "$record_type" | awk -v domain="$domain" '$1 == domain"." {print $5; exit}')"
	[ -n "$gip" ] && info="$(curl -s "https://ipinfo.io/${gip}" | jq -r '.org + " @ " + .city + " / " + .country' 2>/dev/null)" && echo "[DNS/${label_family}] ${domain} --> ${gip} [${info}]"
}

test_dns() {
	config_file="$(resolve_config_file)"
	command -v yq >/dev/null 2>&1 || {
		echo "[DNS] yq not available, skip dns tests"
		return 0
	}
	for family in ipv4 ipv6; do
		yq -r ".status_tests.dns.${family}[]? // empty" "$config_file" 2>/dev/null | while IFS= read -r domain; do
			[ -n "$domain" ] && test_dns_domain "$family" "$domain"
		done
	done
}

ensure_proxy() {
	name="$1"
	family="$2"
	case "$family" in
		ipv4)
			record_type="a"
			set_name="trafix"
			;;
		ipv6)
			record_type="aaaa"
			set_name="trafix6"
			;;
		*)
			return 1
			;;
	esac
	ips="$(nslookup -type="$record_type" "$name" | awk '/Address / && $3 != "127.0.0.1" {print $3}')"
	for ip in $ips; do
		ipset -q test "$set_name" "$ip" || {
			echo "ipset add ${set_name} ${ip} for ${name}"
			run_cmd "ipset add ${set_name} \"$ip\""
		}
	done
}

status_http_test() {
	action="$1"
	family="$2"
	domain="$3"
	url="$4"
	case "$family" in
		ipv4)
			curl_flag="-4"
			;;
		ipv6)
			curl_flag="-6"
			;;
		*)
			return 1
			;;
	esac
	[ "$action" = "proxy" ] && ensure_proxy "$domain" "$family"
	label_action=$(printf "%s" "$action" | tr "[:lower:]" "[:upper:]")
	label_family=$(printf "%s" "$family" | tr "[:lower:]" "[:upper:]")
	check_ip "[${label_action}/${label_family}] ${domain}" "$(curl -s ${curl_flag} "$url" 2>/dev/null)"
}

status_group() {
	action="$1"
	family="$2"
	config_file="$3"
	command -v yq >/dev/null 2>&1 || {
		echo "[status/${action}/${family}] yq not available, skip"
		return 0
	}
	yq -o=json ".status_tests.${action}.${family} // []" "$config_file" 2>/dev/null | \
		jq -r '.[]? | [.domain // "", .url // ""] | @tsv' | \
		while IFS="$(printf '\t')" read -r domain url; do
			[ -n "$domain" ] && [ -n "$url" ] && status_http_test "$action" "$family" "$domain" "$url"
		done
}

status() {
	config_file="$(resolve_config_file)"
	status_group proxy ipv4 "$config_file"
	status_group proxy ipv6 "$config_file"
	status_group bypass ipv4 "$config_file"
	status_group bypass ipv6 "$config_file"
	test_dns
}

load_runtime_env() {
	if [ -f "$RUNTIME_ENV" ]; then
		. "$RUNTIME_ENV"
	else
		FINAL_ACTION=bypass
	fi
}

add_entries() {
	set_name="$1"
	file_path="$2"
	[ -f "$file_path" ] || return 0
	while IFS= read -r value; do
		[ -n "$value" ] && run_cmd "ipset -q add \"$set_name\" \"$value\""
	done < "$file_path"
}

setup_ipset_ipv4() {
	run_cmd "ipset create trafix hash:ip 2>/dev/null"
	add_entries trafix "$PROXY_IPSET_CONF"

	run_cmd "ipset create trafix-net hash:net 2>/dev/null"
	add_entries trafix-net "$PROXY_IPSET_NET_CONF"

	run_cmd "ipset create trafix-bypass hash:ip 2>/dev/null"
	add_entries trafix-bypass "$BYPASS_IPSET_CONF"

	run_cmd "ipset create trafix-bypass-net hash:net 2>/dev/null"
	add_entries trafix-bypass-net "$BYPASS_IPSET_NET_CONF"

	run_cmd "ipset create trafix-block hash:ip 2>/dev/null"
	add_entries trafix-block "$BLOCK_IPSET_CONF"

	run_cmd "ipset create trafix-block-net hash:net 2>/dev/null"
	add_entries trafix-block-net "$BLOCK_IPSET_NET_CONF"
}

setup_ipset_ipv6() {
	run_cmd "ipset create trafix6 hash:ip family inet6 2>/dev/null"
	add_entries trafix6 "$PROXY_IP6SET_CONF"

	run_cmd "ipset create trafix6-net hash:net family inet6 2>/dev/null"
	add_entries trafix6-net "$PROXY_IP6SET_NET_CONF"

	run_cmd "ipset create trafix6-bypass hash:ip family inet6 2>/dev/null"
	add_entries trafix6-bypass "$BYPASS_IP6SET_CONF"

	run_cmd "ipset create trafix6-bypass-net hash:net family inet6 2>/dev/null"
	add_entries trafix6-bypass-net "$BYPASS_IP6SET_NET_CONF"

	run_cmd "ipset create trafix6-block hash:ip family inet6 2>/dev/null"
	add_entries trafix6-block "$BLOCK_IP6SET_CONF"

	run_cmd "ipset create trafix6-block-net hash:net family inet6 2>/dev/null"
	add_entries trafix6-block-net "$BLOCK_IP6SET_NET_CONF"
}

setup_block_filter_ipv4() {
	run_cmd "iptables -N TRAFIX_FILTER 2>/dev/null"
	run_cmd "iptables -C FORWARD -j TRAFIX_FILTER 2>/dev/null || iptables -A FORWARD -j TRAFIX_FILTER"
	run_cmd "iptables -C OUTPUT -j TRAFIX_FILTER 2>/dev/null || iptables -A OUTPUT -j TRAFIX_FILTER"
	run_cmd "iptables -C TRAFIX_FILTER -m set --match-set trafix-block dst -j DROP 2>/dev/null || iptables -A TRAFIX_FILTER -m set --match-set trafix-block dst -j DROP"
	run_cmd "iptables -C TRAFIX_FILTER -m set --match-set trafix-block-net dst -j DROP 2>/dev/null || iptables -A TRAFIX_FILTER -m set --match-set trafix-block-net dst -j DROP"
}

setup_block_filter_ipv6() {
	run_cmd "ip6tables -N TRAFIX_FILTER 2>/dev/null"
	run_cmd "ip6tables -C FORWARD -j TRAFIX_FILTER 2>/dev/null || ip6tables -A FORWARD -j TRAFIX_FILTER"
	run_cmd "ip6tables -C OUTPUT -j TRAFIX_FILTER 2>/dev/null || ip6tables -A OUTPUT -j TRAFIX_FILTER"
	run_cmd "ip6tables -C TRAFIX_FILTER -m set --match-set trafix6-block dst -j DROP 2>/dev/null || ip6tables -A TRAFIX_FILTER -m set --match-set trafix6-block dst -j DROP"
	run_cmd "ip6tables -C TRAFIX_FILTER -m set --match-set trafix6-block-net dst -j DROP 2>/dev/null || ip6tables -A TRAFIX_FILTER -m set --match-set trafix6-block-net dst -j DROP"
}

setup_http3_block_ipv4() {
	port_policy="$1"
	config_get_bool block_proxy_http3 'general' 'block_proxy_http3'
	[ "$block_proxy_http3" = 1 ] || return 0

	run_cmd "iptables -C TRAFIX_FILTER -p udp --dport 443 -m set --match-set trafix-block dst -j DROP 2>/dev/null || iptables -A TRAFIX_FILTER -p udp --dport 443 -m set --match-set trafix-block dst -j DROP"
	run_cmd "iptables -C TRAFIX_FILTER -p udp --dport 443 -m set --match-set trafix-block-net dst -j DROP 2>/dev/null || iptables -A TRAFIX_FILTER -p udp --dport 443 -m set --match-set trafix-block-net dst -j DROP"

	case "$port_policy" in
		proxy)
			run_cmd "iptables -C TRAFIX_FILTER -m set --match-set trafix-bypass dst -j RETURN 2>/dev/null || iptables -A TRAFIX_FILTER -m set --match-set trafix-bypass dst -j RETURN"
			run_cmd "iptables -C TRAFIX_FILTER -m set --match-set trafix-bypass-net dst -j RETURN 2>/dev/null || iptables -A TRAFIX_FILTER -m set --match-set trafix-bypass-net dst -j RETURN"
			run_cmd "iptables -C TRAFIX_FILTER -p udp --dport 443 -j DROP 2>/dev/null || iptables -A TRAFIX_FILTER -p udp --dport 443 -j DROP"
			;;
		*)
			run_cmd "iptables -C TRAFIX_FILTER -p udp --dport 443 -m set --match-set trafix dst -j DROP 2>/dev/null || iptables -A TRAFIX_FILTER -p udp --dport 443 -m set --match-set trafix dst -j DROP"
			run_cmd "iptables -C TRAFIX_FILTER -p udp --dport 443 -m set --match-set trafix-net dst -j DROP 2>/dev/null || iptables -A TRAFIX_FILTER -p udp --dport 443 -m set --match-set trafix-net dst -j DROP"
			;;
	esac
}

setup_http3_block_ipv6() {
	port_policy="$1"
	config_get_bool block_proxy_http3 'general' 'block_proxy_http3'
	[ "$block_proxy_http3" = 1 ] || return 0

	run_cmd "ip6tables -C TRAFIX_FILTER -p udp --dport 443 -m set --match-set trafix6-block dst -j DROP 2>/dev/null || ip6tables -A TRAFIX_FILTER -p udp --dport 443 -m set --match-set trafix6-block dst -j DROP"
	run_cmd "ip6tables -C TRAFIX_FILTER -p udp --dport 443 -m set --match-set trafix6-block-net dst -j DROP 2>/dev/null || ip6tables -A TRAFIX_FILTER -p udp --dport 443 -m set --match-set trafix6-block-net dst -j DROP"

	case "$port_policy" in
		proxy)
			run_cmd "ip6tables -C TRAFIX_FILTER -m set --match-set trafix6-bypass dst -j RETURN 2>/dev/null || ip6tables -A TRAFIX_FILTER -m set --match-set trafix6-bypass dst -j RETURN"
			run_cmd "ip6tables -C TRAFIX_FILTER -m set --match-set trafix6-bypass-net dst -j RETURN 2>/dev/null || ip6tables -A TRAFIX_FILTER -m set --match-set trafix6-bypass-net dst -j RETURN"
			run_cmd "ip6tables -C TRAFIX_FILTER -p udp --dport 443 -j DROP 2>/dev/null || ip6tables -A TRAFIX_FILTER -p udp --dport 443 -j DROP"
			;;
		*)
			run_cmd "ip6tables -C TRAFIX_FILTER -p udp --dport 443 -m set --match-set trafix6 dst -j DROP 2>/dev/null || ip6tables -A TRAFIX_FILTER -p udp --dport 443 -m set --match-set trafix6 dst -j DROP"
			run_cmd "ip6tables -C TRAFIX_FILTER -p udp --dport 443 -m set --match-set trafix6-net dst -j DROP 2>/dev/null || ip6tables -A TRAFIX_FILTER -p udp --dport 443 -m set --match-set trafix6-net dst -j DROP"
			;;
	esac
}

setup_redir_iptables_ipv4() {
	port="$1"
	load_runtime_env

	run_cmd "iptables -t nat -N TRAFIX 2>/dev/null"
	run_cmd "iptables -t nat -C TRAFIX -m set --match-set trafix-bypass dst -j RETURN 2>/dev/null || iptables -t nat -A TRAFIX -m set --match-set trafix-bypass dst -j RETURN"
	run_cmd "iptables -t nat -C TRAFIX -m set --match-set trafix-bypass-net dst -j RETURN 2>/dev/null || iptables -t nat -A TRAFIX -m set --match-set trafix-bypass-net dst -j RETURN"

	case "$FINAL_ACTION" in
		proxy)
			run_cmd "iptables -t nat -C TRAFIX -p tcp -j REDIRECT --to-ports \"$port\" 2>/dev/null || iptables -t nat -A TRAFIX -p tcp -j REDIRECT --to-ports \"$port\""
			setup_http3_block_ipv4 proxy
			;;
		*)
			run_cmd "iptables -t nat -C TRAFIX -p tcp -m set --match-set trafix dst -j REDIRECT --to-ports \"$port\" 2>/dev/null || iptables -t nat -A TRAFIX -p tcp -m set --match-set trafix dst -j REDIRECT --to-ports \"$port\""
			run_cmd "iptables -t nat -C TRAFIX -p tcp -m set --match-set trafix-net dst -j REDIRECT --to-ports \"$port\" 2>/dev/null || iptables -t nat -A TRAFIX -p tcp -m set --match-set trafix-net dst -j REDIRECT --to-ports \"$port\""
			setup_http3_block_ipv4 bypass
			;;
	esac

	run_cmd "iptables -t nat -C PREROUTING -j TRAFIX 2>/dev/null || iptables -t nat -A PREROUTING -j TRAFIX"
	run_cmd "iptables -t nat -C OUTPUT -j TRAFIX 2>/dev/null || iptables -t nat -A OUTPUT -j TRAFIX"
}

setup_redir_iptables_ipv6() {
	port="$1"
	load_runtime_env

	run_cmd "ip6tables -t nat -N TRAFIX 2>/dev/null"
	run_cmd "ip6tables -t nat -C TRAFIX -m set --match-set trafix6-bypass dst -j RETURN 2>/dev/null || ip6tables -t nat -A TRAFIX -m set --match-set trafix6-bypass dst -j RETURN"
	run_cmd "ip6tables -t nat -C TRAFIX -m set --match-set trafix6-bypass-net dst -j RETURN 2>/dev/null || ip6tables -t nat -A TRAFIX -m set --match-set trafix6-bypass-net dst -j RETURN"

	case "$FINAL_ACTION" in
		proxy)
			run_cmd "ip6tables -t nat -C TRAFIX -p tcp -j REDIRECT --to-ports \"$port\" 2>/dev/null || ip6tables -t nat -A TRAFIX -p tcp -j REDIRECT --to-ports \"$port\""
			setup_http3_block_ipv6 proxy
			;;
		*)
			run_cmd "ip6tables -t nat -C TRAFIX -p tcp -m set --match-set trafix6 dst -j REDIRECT --to-ports \"$port\" 2>/dev/null || ip6tables -t nat -A TRAFIX -p tcp -m set --match-set trafix6 dst -j REDIRECT --to-ports \"$port\""
			run_cmd "ip6tables -t nat -C TRAFIX -p tcp -m set --match-set trafix6-net dst -j REDIRECT --to-ports \"$port\" 2>/dev/null || ip6tables -t nat -A TRAFIX -p tcp -m set --match-set trafix6-net dst -j REDIRECT --to-ports \"$port\""
			setup_http3_block_ipv6 bypass
			;;
	esac

	run_cmd "ip6tables -t nat -C PREROUTING -j TRAFIX 2>/dev/null || ip6tables -t nat -A PREROUTING -j TRAFIX"
	run_cmd "ip6tables -t nat -C OUTPUT -j TRAFIX 2>/dev/null || ip6tables -t nat -A OUTPUT -j TRAFIX"
}

start() {
	config_load 'trafix'
	config_get port4 'general' 'redir_ipv4_port'
	config_get port6 'general' 'redir_ipv6_port'

	setup_ipset_ipv4
	setup_ipset_ipv6
	setup_block_filter_ipv4
	setup_block_filter_ipv6
	setup_redir_iptables_ipv4 "$port4"
	setup_redir_iptables_ipv6 "$port6"
}

cleanup_filter_ipv4() {
	run_cmd "iptables -D FORWARD -j TRAFIX_FILTER 2>/dev/null"
	run_cmd "iptables -D OUTPUT -j TRAFIX_FILTER 2>/dev/null"
	run_cmd "iptables -F TRAFIX_FILTER 2>/dev/null"
	run_cmd "iptables -X TRAFIX_FILTER 2>/dev/null"
}

cleanup_filter_ipv6() {
	run_cmd "ip6tables -D FORWARD -j TRAFIX_FILTER 2>/dev/null"
	run_cmd "ip6tables -D OUTPUT -j TRAFIX_FILTER 2>/dev/null"
	run_cmd "ip6tables -F TRAFIX_FILTER 2>/dev/null"
	run_cmd "ip6tables -X TRAFIX_FILTER 2>/dev/null"
}

cleanup_redir_iptables_ipv4() {
	run_cmd "iptables -t nat -D PREROUTING -j TRAFIX 2>/dev/null"
	run_cmd "iptables -t nat -D OUTPUT -j TRAFIX 2>/dev/null"
	run_cmd "iptables -t nat -F TRAFIX 2>/dev/null"
	run_cmd "iptables -t nat -X TRAFIX 2>/dev/null"
	cleanup_filter_ipv4
}

cleanup_redir_iptables_ipv6() {
	run_cmd "ip6tables -t nat -D PREROUTING -j TRAFIX 2>/dev/null"
	run_cmd "ip6tables -t nat -D OUTPUT -j TRAFIX 2>/dev/null"
	run_cmd "ip6tables -t nat -F TRAFIX 2>/dev/null"
	run_cmd "ip6tables -t nat -X TRAFIX 2>/dev/null"
	cleanup_filter_ipv6
}

stop() {
	cleanup_redir_iptables_ipv4
	cleanup_redir_iptables_ipv6
}

dryrun_start() {
	DRY_RUN=1
	load_runtime_env
	echo "# dry-run start (FINAL_ACTION=${FINAL_ACTION})"
	start
}

dryrun_stop() {
	DRY_RUN=1
	echo "# dry-run stop"
	stop
}

dryrun_restart() {
	DRY_RUN=1
	load_runtime_env
	echo "# dry-run restart (FINAL_ACTION=${FINAL_ACTION})"
	stop
	start
}
